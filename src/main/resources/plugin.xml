<?xml version="1.0" encoding="UTF-8"?>
<plugin>
    <class>com.igniterealtime.openfire.plugin.federation.FederationPlugin</class>

    <name>Federation</name>
    <description>Better MUC federation with dynamic routing, live activation, and multi-hop forwarding.</description>
    <author>Your Name</author>
    <version>1.3.12</version>
    <date>06/17/2026</date>
    <url>https://github.com/your-org/openfire-federation-plugin</url>
    <minServerVersion>5.0.5</minServerVersion>
    <licenseType>apache</licenseType>

    <adminconsole>
        <!--
            Creates a new top-level tab "Federation" in the Openfire admin console.
            order="20" places it after the standard tabs (Server=1, Users=2, Sessions=3, ...).
        -->
        <tab id="tab-federation"
             name="Federation"
             url="index.html"
             description="Manage server federation"
             order="20">
            <sidebar id="sidebar-federation"
                     name="Federation"
                     description="Federation management">
                <item id="federation-overview"
                      name="Overview"
                      url="index.html"
                      description="Peers, routing table, and federated rooms"
                      order="1"/>
            </sidebar>
        </tab>
    </adminconsole>
</plugin>

<?xml version="1.0" encoding="UTF-8"?>
<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.1.1"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.1.1
                              http://maven.apache.org/xsd/assembly-2.1.1.xsd">
    <id>openfire-plugin</id>
    <formats>
        <format>jar</format>
    </formats>
    <includeBaseDirectory>false</includeBaseDirectory>

    <!-- plugin.xml + readme.html at the archive root.
         Openfire shows the "readme" (documentation) link on the Plugins admin page
         when readme.html is present at the plugin root, next to plugin.xml. -->
    <files>
        <file>
            <source>src/main/resources/plugin.xml</source>
            <outputDirectory>/</outputDirectory>
        </file>
        <file>
            <source>src/main/resources/readme.html</source>
            <outputDirectory>/</outputDirectory>
        </file>
    </files>

    <!-- JSP / JS admin UI files -->
    <fileSets>
        <fileSet>
            <directory>src/main/webapp</directory>
            <outputDirectory>web</outputDirectory>
        </fileSet>
    </fileSets>

    <!--
        The compiled classes JAR goes into lib/.
        Openfire's PluginClassLoader adds every lib/*.jar to the plugin's classpath.
        Provided-scope deps (xmppserver, dom4j, etc.) are excluded — they are
        already on the Openfire classloader and must not be duplicated here.
    -->
    <dependencySets>
        <dependencySet>
            <outputDirectory>lib</outputDirectory>
            <useProjectArtifact>true</useProjectArtifact>
            <useTransitiveDependencies>false</useTransitiveDependencies>
            <includes>
                <include>${project.groupId}:${project.artifactId}</include>
            </includes>
        </dependencySet>
        <!--
            Bundled (non-provided) runtime dependencies — currently just the content-sniffing
            library used by the file-relay ingress type-verification gate. Explicit include (not a
            scope filter): Maven's ScopeArtifactFilter treats "compile" as "everything visible on
            the compile classpath", which would also sweep in every provided-scope dep above and
            duplicate them alongside Openfire's own classloader copies. useTransitiveDependencies
            pulls tika-core's own transitive (commons-io) along automatically.
        -->
        <dependencySet>
            <outputDirectory>lib</outputDirectory>
            <useProjectArtifact>false</useProjectArtifact>
            <useTransitiveDependencies>true</useTransitiveDependencies>
            <includes>
                <!-- useTransitiveDependencies pulls commons-io into CONSIDERATION, but the
                     includes filter is still applied per-artifact — it must be listed too, or
                     it's silently dropped and tika-core throws NoClassDefFoundError at runtime. -->
                <include>org.apache.tika:tika-core</include>
                <include>commons-io:commons-io</include>
            </includes>
        </dependencySet>
    </dependencySets>
</assembly>
